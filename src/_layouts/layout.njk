{%- set webfontUrl = '/assets/fonts/fonts.css' | url | cachebust -%}
{%- set colorSchemeJsUrl = '/assets/javascript/color-scheme.js' | url | cachebust -%}

<!doctype html>
<html lang="en-GB" class="kimPage">
<head>

  {#- Preload stuff #}
  <link rel="preload" as="style" href="{{ webfontUrl }}">
  <link rel="preload" as="script" href="{{ colorSchemeJsUrl }}">

  {#- Technical metadata #}
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <link rel="alternate" type="application/atom+xml" title="{{ site.blogName }}" href="{{ '/feed.xml' | url }}">
  {%- for item in site.relMe %}
    <link rel="me" href="{{ item }}">
  {%- endfor %}
  <link rel="webmention" href="https://webmention.io/beeps.website/webmention">
  <link rel="pingback" href="https://webmention.io/beeps.website/xmlrpc">
  
  {#- Page title #}
  {%- set pageTitle %}
    {{- (metadata.title or title) | markdownInline | safe | striptags -}}
    {%- if not isFullTitle -%}
      {%- if mastheadSection %} / {{ mastheadSection.text | markdownInline | safe | striptags }}{% endif %} / {{ site.name }}
    {%- endif -%}
  {%- endset %}
  <title>{{ pageTitle }}</title>

  {#- Stylesheets #}
  <link rel="stylesheet" href="{{ webfontUrl }}" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="{{ webfontUrl }}"></noscript>
  <link rel="stylesheet" href="{{ '/assets/stylesheet.css' | url | cachebust }}" media="all">
  
  {# Color scheme switcher JS #}
  <script src="{{ colorSchemeJsUrl }}"></script>
  
  {% include "src/_includes/page-head.njk" %}
  
  {#- Page-specific head content #}
  {% block head %}{% endblock %}
  
</head>
<body class="kimPage_body {% if bodyClasses %} {{ bodyClasses }}{% endif %}">
  
  {% block beforeMasthead %}
  {% include "src/_includes/development-tag.njk" %}
    <div class="kimWrapper" style="position: relative">
      <a class="kimSkiplink" href="#content">
        <div class="kimWrapper">
          Skip to main content
        </div>
      </a>
    </div>
  {% endblock %}
  {% block masthead %}
    <header class="kimMasthead" data-js="masthead">
      <div class="kimWrapper kimMasthead_inner">
        <a class="kimMasthead_brand" href="{{ '/' | url }}">
          <span class="kimMasthead_logo">{% include "logo.njk" %}</span>
          <span class="kimMasthead_name">{{ site.name }}</span>
        </a>
        {%- if mastheadSection %}
          <a class="kimMasthead_section" href="{{ mastheadSection.href | url }}">
            {{- mastheadSection.text -}}
          </a>
        {%- endif %}
        <a class="kimMasthead_nav-link" href="{{ '/sitemap/' | url }}">Sitemap</a>
        <button class="kimMasthead_nav-toggle" type="button" aria-controls="navigation" hidden>
          Menu
        </button>
      </div>
    </header>
    <hr class="kim-!-visually-hidden">
  {% endblock %}
  {% block afterMasthead %}
    <div class="kimNavigation" id="navigation" hidden>
      <div class="kimWrapper kimNavigation_inner">
        <div class="kimGrid">
          {%- for section in site.navigationLinks %}
            <div class="kimGrid_column kimGrid_column-full nx:kimGrid_column-oneHalf defiant:kimGrid_column-oneThird">
              <h2 class="kimHeading-xs">{{ section.heading }}</h2>
              <ul class="kimList">
                {%- for link in section.items %}
                  <li>
                    <a class="kimNavigation_link" href="{{ link.href | url }}" {%- for attribute, value in link.attributes %} {{ attribute }}="{{ value }}"{% endfor %}>
                      {{- link.text -}}
                    </a>
                  </li>
                {%- endfor%}
              </ul>
            </div>
          {%- endfor %}
        </div>
      </div>
    </div>
  {% endblock %}

  <main id="content">
    {% block main %}{% endblock %}
  </main>
  
  {% block footer %}
    <hr class="kim-!-visually-hidden">
    {% block footerDecor %}
      <div class="kimNoodleBowl" role="presentation">
        <canvas class="kimNoodleBowl_canvas"></canvas>
        <div class="kimNoodleBowl_inner"></div>
      </div>
    {% endblock %}
    <footer class="kimFooter">
      <div class="kimWrapper kimFooter_inner">
        {% block beforeFooter %}{% endblock%}
        {%- if site.footerLinks %}
          <ul class="kimList kimList-inline kimBody-s">
          {%- for link in site.footerLinks %}
            <li>
              <a class="kimLink-stealth" href="{{ link.href | url }}" {%- for attribute, value in link.attributes %} {{ attribute }}="{{ value }}"{% endfor %}>
                {{- link.text -}}
              </a>
            </li>
          {%- endfor%}
          </ul>
        {%- endif %}
        {% block copyrights %}
        <small class="kimFooter_smallprint kimBody-s">Artwork by <a class="kimLink-stealth" href="http://tuxedodragon.art/">TuxedoDragon</a>. Text content licensed under <a class="kimLink-stealth" href="http://creativecommons.org/licenses/by-nc/4.0/" title="Creative Commons Attribution Non-Commercial 4.0">CC BY-NC 4.0</a>. Code available under the <a class="kimLink-stealth" href="https://github.com/querkmachine/beeps.website/blob/main/LICENCE">MIT license</a>. Keep circulating <a class="kimLink-stealth" href="https://github.com/querkmachine/beeps.website">the HTML</a>.</small>
        {% endblock %}
        {% block afterFooter %}{% endblock %}
      </div>
    </footer>
  {% endblock %}
  
  {# Other scripts #}
  {% block scripts %}
  <script type="module" src="{{ '/assets/javascript/entry.js' | url | cachebust }}"></script>
  <script type="module">
    import Spots from "{{ '/assets/javascript/spots.js' | url | cachebust }}";
    new Spots(document.querySelector(".kimNoodleBowl_canvas"), {
      isAnimated: true
    });
  </script>
  {% endblock %}
  
</body>
</html>
